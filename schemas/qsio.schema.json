    "qsi": { "type": "object" },
    "pre_state_hashes": { "type": "object" },
    "proposed_transitions": { "type": "array" },
    "accepted_transitions": { "type": "array" },
    "witnesses": { "type": "array" },
    "outcome": { "type": "string" },
    "reason_codes": { "type": "array", "items": { "type": "string" } },
    "parent_qsio_hashes": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string" },
    "content_hash": { "type": "string" }
  },
  "additionalProperties": false
}
